    Home = "rbxassetid://134112637052391",
    Settings = "rbxassetid://121005722030214",
    User = "rbxasset://textures/ui/GuiImage/Avatar.png",
    Shield = "rbxasset://textures/ui/GuiImage/Lock.png",
    Search = "rbxasset://textures/ui/GuiImage/Search.png",
    Close = "rbxassetid://94295066371757",
    Minimize = "rbxassetid://79396743523839",
    Maximize = "rbxassetid://103730626135376",
    ChevronDown = "rbxassetid://73584794924965",
    Check = "rbxasset://textures/ui/GuiImage/Checkmark.png"
}

function Library:CreateWindow(config)
    config = config or {}
    local WindowTitle = config.Title or "Black UI"
    local WindowIcon = config.Icon or Icons.Settings

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "BlackUI"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.DisplayOrder = 100
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.Parent = game.CoreGui

    local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
    local viewportSize = Workspace.CurrentCamera and Workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)
    local maxWidth = 600
    local maxHeight = isMobile and math.min(400, viewportSize.Y * 0.88) or 400

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, maxWidth, 0, maxHeight)
    MainFrame.Position = UDim2.new(0.5, -maxWidth/2, 0.5, -maxHeight/2)
    MainFrame.BackgroundColor3 = Theme.Background
    MainFrame.BackgroundTransparency = 0.2
    MainFrame.BorderSizePixel = 0
    MainFrame.ZIndex = 1
    MainFrame.Parent = ScreenGui
    MakeRound(MainFrame, 12)
    AddStroke(MainFrame, Theme.Border, 2)
    table.insert(GUIElements, {Instance = MainFrame, Key = "Background", Property = "BackgroundColor3"})

    local Topbar = Instance.new("Frame")
    Topbar.Size = UDim2.new(1, 0, 0, 30)
    Topbar.BackgroundColor3 = Theme.Sidebar
    Topbar.BorderSizePixel = 0
    Topbar.Parent = MainFrame
    MakeRound(Topbar, 12)
    table.insert(GUIElements, {Instance = Topbar, Key = "Sidebar", Property = "BackgroundColor3"})

    local TopbarFix = Instance.new("Frame")
    TopbarFix.Size = UDim2.new(1, 0, 0, 10)
    TopbarFix.Position = UDim2.new(0, 0, 1, -10)
    TopbarFix.BackgroundColor3 = Theme.Sidebar
    TopbarFix.BackgroundTransparency = 0
    TopbarFix.BorderSizePixel = 0
    TopbarFix.Parent = Topbar

    local LogoIcon = Instance.new("ImageLabel")
    LogoIcon.Size = UDim2.new(0, 22, 0, 22)
    LogoIcon.Position = UDim2.new(0, 12, 0.5, -11)
    LogoIcon.BackgroundTransparency = 1
    LogoIcon.ImageColor3 = Theme.Text
    LogoIcon.Parent = Topbar
    SetImageSafe(LogoIcon, WindowIcon)
    table.insert(GUIElements, {Instance = LogoIcon, Key = "Text", Property = "ImageColor3"})

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(0, 200, 1, 0)
    TitleLabel.Position = UDim2.new(0, 40, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = WindowTitle
    TitleLabel.TextColor3 = Theme.Text
    TitleLabel.TextSize = 16
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = Topbar
    table.insert(GUIElements, {Instance = TitleLabel, Key = "Text", Property = "TextColor3"})

    local MinimizeBtn = Instance.new("TextButton")
    MinimizeBtn.Size = UDim2.new(0, 25, 0, 25)
    MinimizeBtn.Position = UDim2.new(1, -72, 0.5, -13)
    MinimizeBtn.BackgroundColor3 = Theme.Secondary
    MinimizeBtn.BackgroundTransparency = transparency
    MinimizeBtn.Text = ""
    MinimizeBtn.Parent = Topbar
    MakeRound(MinimizeBtn, 7)
    table.insert(GUIElements, {Instance = MinimizeBtn, Key = "Secondary", Property = "BackgroundColor3"})

    local MinimizeIcon = Instance.new("ImageLabel")
    MinimizeIcon.Size = UDim2.new(0, 16, 0, 16)
    MinimizeIcon.Position = UDim2.new(0.5, -8, 0.5, -8)
    MinimizeIcon.BackgroundTransparency = 1
    MinimizeIcon.ImageColor3 = Theme.Text
    MinimizeIcon.Parent = MinimizeBtn
    SetImageSafe(MinimizeIcon, Icons.Minimize)
    table.insert(GUIElements, {Instance = MinimizeIcon, Key = "Text", Property = "ImageColor3"})

    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0, 25, 0, 25)
    CloseBtn.Position = UDim2.new(1, -36, 0.5, -13)
    CloseBtn.BackgroundColor3 = Theme.Primary
    CloseBtn.BackgroundTransparency = transparency
    CloseBtn.Text = ""
    CloseBtn.Parent = Topbar
    MakeRound(CloseBtn, 7)
    table.insert(GUIElements, {Instance = CloseBtn, Key = "Primary", Property = "BackgroundColor3"})

    local CloseIcon = Instance.new("ImageLabel")
    CloseIcon.Size = UDim2.new(0, 16, 0, 16)
    CloseIcon.Position = UDim2.new(0.5, -8, 0.5, -8)
    CloseIcon.BackgroundTransparency = 1
    CloseIcon.ImageColor3 = Theme.Text
    CloseIcon.Parent = CloseBtn
    SetImageSafe(CloseIcon, Icons.Close)
    table.insert(GUIElements, {Instance = CloseIcon, Key = "Text", Property = "ImageColor3"})

    local Sidebar = Instance.new("Frame")
    Sidebar.Size = UDim2.new(0, 140, 1, -30)
    Sidebar.Position = UDim2.new(0, 0, 0, 30)
    Sidebar.BackgroundColor3 = Theme.Sidebar
    Sidebar.BackgroundTransparency = 0.5
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame
    MakeRound(Sidebar, 12)
    table.insert(GUIElements, {Instance = Sidebar, Key = "Sidebar", Property = "BackgroundColor3"})

    local SidebarList = Instance.new("UIListLayout")
    SidebarList.SortOrder = Enum.SortOrder.LayoutOrder
    SidebarList.Padding = UDim.new(0, 4)
    SidebarList.Parent = Sidebar

    local SidebarPadding = Instance.new("UIPadding")
    SidebarPadding.PaddingTop = UDim.new(0, 8)
    SidebarPadding.PaddingLeft = UDim.new(0, 8)
    SidebarPadding.PaddingRight = UDim.new(0, 8)
    SidebarPadding.Parent = Sidebar

    local ContentArea = Instance.new("Frame")
    ContentArea.Size = UDim2.new(1, -150, 1, -35)
    ContentArea.Position = UDim2.new(0, 145, 0, 35)
    ContentArea.BackgroundTransparency = 1
    ContentArea.BorderSizePixel = 0
    ContentArea.ClipsDescendants = true
    ContentArea.Parent = MainFrame

    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        Tween(MainFrame, {Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)}, 0.1)
    end

    Topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    Topbar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)

    local FloatingButton = Instance.new("ImageButton")
    FloatingButton.Size = UDim2.new(0, 45, 0, 45)
    FloatingButton.Position = UDim2.new(1, -70, 0, 15)
    FloatingButton.BackgroundColor3 = Theme.Primary
    FloatingButton.BackgroundTransparency = 1
    FloatingButton.BorderSizePixel = 0
    FloatingButton.Visible = false
    FloatingButton.ImageColor3 = Theme.Text
    FloatingButton.ScaleType = Enum.ScaleType.Fit
    FloatingButton.Parent = ScreenGui
    MakeRound(FloatingButton, 25)
    SetImageSafe(FloatingButton, WindowIcon)
    table.insert(GUIElements, {Instance = FloatingButton, Key = "Primary", Property = "BackgroundColor3"})
    table.insert(GUIElements, {Instance = FloatingButton, Key = "Text", Property = "ImageColor3"})

    local draggingFloat, dragInputFloat, dragStartFloat, startPosFloat
    local function updateFloat(input)
        local delta = input.Position - dragStartFloat
        Tween(FloatingButton, {Position = UDim2.new(startPosFloat.X.Scale, startPosFloat.X.Offset + delta.X, startPosFloat.Y.Scale, startPosFloat.Y.Offset + delta.Y)}, 0.1)
    end

    FloatingButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingFloat = true
            dragStartFloat = input.Position
            startPosFloat = FloatingButton.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    draggingFloat = false
                end
            end)
        end
    end)

    FloatingButton.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInputFloat = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInputFloat and draggingFloat then
            updateFloat(input)
        end
    end)

    MinimizeBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = false
        FloatingButton.Visible = true
    end)

    FloatingButton.MouseButton1Click:Connect(function()
        if not draggingFloat then
            FloatingButton.Visible = false
            MainFrame.Visible = true
        end
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        ShowConfirmationModal(ScreenGui, "Close this window?", function(confirmed)
            if confirmed then
                ScreenGui:Destroy()
            end
        end)
    end)

    local Window = {
        Tabs = {},
        CurrentTab = nil,
        ScreenGui = ScreenGui
    }

    function Window:CreateTab(config)
        config = config or {}
        local TabName = config.Name or "Tab"
        local TabIcon = config.Icon or Icons.Home

        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(1, 0, 0, 36)
        TabBtn.BackgroundColor3 = Theme.Input
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = ""
        TabBtn.Parent = Sidebar
        MakeRound(TabBtn, 7)
        table.insert(GUIElements, {Instance = TabBtn, Key = "Input", Property = "BackgroundColor3"})

        local TabIcon_img = Instance.new("ImageLabel")
        TabIcon_img.Size = UDim2.new(0, 18, 0, 18)
        TabIcon_img.Position = UDim2.new(0, 8, 0.5, -9)
        TabIcon_img.BackgroundTransparency = 1
        TabIcon_img.ImageColor3 = Theme.TextDim
        TabIcon_img.Parent = TabBtn
        SetImageSafe(TabIcon_img, TabIcon)
        table.insert(GUIElements, {Instance = TabIcon_img, Key = "TextDim", Property = "ImageColor3"})

        local TabLabel = Instance.new("TextLabel")
        TabLabel.Size = UDim2.new(1, -45, 1, 0)
        TabLabel.Position = UDim2.new(0, 40, 0, 0)
        TabLabel.BackgroundTransparency = 1
        TabLabel.Text = TabName
        TabLabel.TextColor3 = Theme.TextDim
        TabLabel.TextSize = 13
        TabLabel.Font = Enum.Font.Gotham
        TabLabel.TextXAlignment = Enum.TextXAlignment.Left
        TabLabel.Parent = TabBtn
        table.insert(GUIElements, {Instance = TabLabel, Key = "TextDim", Property = "TextColor3"})

        local TabContent = Instance.new("ScrollingFrame")
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.BorderSizePixel = 0
        TabContent.ScrollBarThickness = 4
        TabContent.ScrollBarImageColor3 = Theme.Primary
        TabContent.Visible = false
        TabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
        TabContent.Parent = ContentArea
        table.insert(GUIElements, {Instance = TabContent, Key = "Primary", Property = "ScrollBarImageColor3"})

        local ContentList = Instance.new("UIListLayout")
        ContentList.SortOrder = Enum.SortOrder.LayoutOrder
        ContentList.Padding = UDim.new(0, 6)
        ContentList.Parent = TabContent

        local ContentPadding = Instance.new("UIPadding")
        ContentPadding.PaddingTop = UDim.new(0, 4)
        ContentPadding.PaddingLeft = UDim.new(0, 5)
        ContentPadding.PaddingRight = UDim.new(0, 5)
        ContentPadding.PaddingBottom = UDim.new(0, 10)
        ContentPadding.Parent = TabContent

        ContentList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            TabContent.CanvasSize = UDim2.new(0, 0, 0, ContentList.AbsoluteContentSize.Y + 10)
        end)

        TabBtn.MouseButton1Click:Connect(function()
            for _, tab in pairs(Window.Tabs) do
                tab.Button.BackgroundTransparency = 1
                tab.Icon.ImageColor3 = Theme.TextDim
                tab.Label.TextColor3 = Theme.TextDim
                tab.Content.Visible = false
            end
            TabBtn.BackgroundTransparency = 0
            TabBtn.BackgroundColor3 = Theme.Primary
            TabIcon_img.ImageColor3 = Theme.Text
            TabLabel.TextColor3 = Theme.Text
            TabContent.Visible = true
            Window.CurrentTab = Tab
            ApplyTheme()
        end)

        local Tab = {
            Button = TabBtn,
            Icon = TabIcon_img,
            Label = TabLabel,
            Content = TabContent,
            ScreenGui = ScreenGui
        }

        function Tab:AddButton(config)
            config = config or {}
            local ButtonText = config.Text or "Button"
            local Description = config.Description
            local Callback = config.Callback or function() end
            local height = Description and 45 or 35

            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, height)
            Frame.BackgroundColor3 = Theme.Input
            Frame.BackgroundTransparency = transparency
            Frame.BorderSizePixel = 0
            Frame.Parent = TabContent
            MakeRound(Frame, 6)
            table.insert(GUIElements, {Instance = Frame, Key = "Input", Property = "BackgroundColor3"})

            local Label = Instance.new("TextLabel")
            Label.BackgroundTransparency = 1
            Label.Text = ButtonText
            Label.TextColor3 = Theme.Text
            Label.TextSize = 14
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Frame
            table.insert(GUIElements, {Instance = Label, Key = "Text", Property = "TextColor3"})

            if Description then
                Label.Size = UDim2.new(1, -90, 0, 24)
                Label.Position = UDim2.new(0, 10, 0, 2)
            else
                Label.Size = UDim2.new(1, -90, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
            end

            if Description then
                local Desc = Instance.new("TextLabel")
                Desc.Size = UDim2.new(1, -90, 0, 12)
                Desc.Position = UDim2.new(0, 10, 0, 24)
                Desc.BackgroundTransparency = 1
                Desc.Text = Description
                Desc.TextColor3 = Theme.TextDim
                Desc.TextSize = 11
                Desc.Font = Enum.Font.Gotham
                Desc.TextXAlignment = Enum.TextXAlignment.Left
                Desc.TextWrapped = true
                Desc.Parent = Frame
                table.insert(GUIElements, {Instance = Desc, Key = "TextDim", Property = "TextColor3"})
            end

            local Button = Instance.new("TextButton")
            Button.Size = UDim2.new(0, 80, 1, 0)
            Button.Position = UDim2.new(1, -90, 0, 0)
            Button.BackgroundTransparency = 1
            Button.Text = "Execute"
            Button.TextColor3 = Theme.Text
            Button.TextSize = 13
            Button.Font = Enum.Font.GothamBold
            Button.Parent = Frame
            table.insert(GUIElements, {Instance = Button, Key = "Text", Property = "TextColor3"})

            Button.MouseButton1Click:Connect(function()
                Tween(Frame, {BackgroundColor3 = Theme.Primary}, 0.1)
                task.wait(0.1)
                Tween(Frame, {BackgroundColor3 = Theme.Input}, 0.1)
                Callback()
            end)

            return Button
        end

        function Tab:AddToggle(config)
            config = config or {}
            local ToggleText = config.Text or "Toggle"
            local Description = config.Description
            local Default = config.Default or false
            local Callback = config.Callback or function() end
            local height = Description and 45 or 35

            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, height)
            Frame.BackgroundColor3 = Theme.Input
            Frame.BackgroundTransparency = transparency
            Frame.BorderSizePixel = 0
            Frame.Parent = TabContent
            MakeRound(Frame, 6)
            table.insert(GUIElements, {Instance = Frame, Key = "Input", Property = "BackgroundColor3"})

            local Label = Instance.new("TextLabel")
            Label.BackgroundTransparency = 1
            Label.Text = ToggleText
            Label.TextColor3 = Theme.Text
            Label.TextSize = 14
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Frame
            table.insert(GUIElements, {Instance = Label, Key = "Text", Property = "TextColor3"})

            if Description then
                Label.Size = UDim2.new(1, -90, 0, 24)
                Label.Position = UDim2.new(0, 10, 0, 2)
            else
                Label.Size = UDim2.new(1, -90, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
            end

            if Description then
                local Desc = Instance.new("TextLabel")
                Desc.Size = UDim2.new(1, -90, 0, 12)
                Desc.Position = UDim2.new(0, 10, 0, 24)
                Desc.BackgroundTransparency = 1
                Desc.Text = Description
                Desc.TextColor3 = Theme.TextDim
                Desc.TextSize = 11
                Desc.Font = Enum.Font.Gotham
                Desc.TextXAlignment = Enum.TextXAlignment.Left
                Desc.TextWrapped = true
                Desc.Parent = Frame
                table.insert(GUIElements, {Instance = Desc, Key = "TextDim", Property = "TextColor3"})
            end

            local ToggleBtn = Instance.new("TextButton")
            ToggleBtn.Size = UDim2.new(0, 36, 0, 18)
            ToggleBtn.Position = UDim2.new(1, -42, 0.5, -9)
            ToggleBtn.BackgroundColor3 = Default and Theme.Primary or Theme.Border
            ToggleBtn.BackgroundTransparency = transparency
            ToggleBtn.Text = ""
            ToggleBtn.Parent = Frame
            MakeRound(ToggleBtn, 9)
            table.insert(GUIElements, {Instance = ToggleBtn, Key = "Primary", Property = "BackgroundColor3"})

            local Circle = Instance.new("Frame")
            Circle.Size = UDim2.new(0, 14, 0, 14)
            Circle.Position = Default and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
            Circle.BackgroundColor3 = Theme.Text
            Circle.BorderSizePixel = 0
            Circle.Parent = ToggleBtn
            MakeRound(Circle, 7)
            table.insert(GUIElements, {Instance = Circle, Key = "Text", Property = "BackgroundColor3"})

            local toggled = Default
            ToggleBtn.MouseButton1Click:Connect(function()
                toggled = not toggled
                Tween(ToggleBtn, {BackgroundColor3 = toggled and Theme.Primary or Theme.Border}, 0.2)
                Tween(Circle, {Position = toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.2)
                Callback(toggled)
            end)

            return {
                Set = function(val)
                    toggled = val
                    Tween(ToggleBtn, {BackgroundColor3 = toggled and Theme.Primary or Theme.Border}, 0.2)
                    Tween(Circle, {Position = toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.2)
                end
            }
        end

        function Tab:AddTextbox(config)
            config = config or {}
            local TextboxText = config.Text or "Input"
            local Description = config.Description
            local Placeholder = config.Placeholder or "..."
            local Callback = config.Callback or function() end
            local height = Description and 45 or 35

            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, height)
            Frame.BackgroundColor3 = Theme.Input
            Frame.BackgroundTransparency = transparency
            Frame.BorderSizePixel = 0
            Frame.Parent = TabContent
            MakeRound(Frame, 6)
            table.insert(GUIElements, {Instance = Frame, Key = "Input", Property = "BackgroundColor3"})

            local Label = Instance.new("TextLabel")
            Label.BackgroundTransparency = 1
            Label.Text = TextboxText
            Label.TextColor3 = Theme.Text
            Label.TextSize = 14
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.TextYAlignment = Enum.TextYAlignment.Top
            Label.Parent = Frame
            table.insert(GUIElements, {Instance = Label, Key = "Text", Property = "TextColor3"})

            if Description then
                Label.Size = UDim2.new(1, -90, 0, 20)
                Label.Position = UDim2.new(0, 10, 0, 7)
            else
                Label.Size = UDim2.new(1, -90, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 10)
            end

            if Description then
                local Desc = Instance.new("TextLabel")
                Desc.Size = UDim2.new(1, -90, 0, 12)
                Desc.Position = UDim2.new(0, 10, 0, 25)
                Desc.BackgroundTransparency = 1
                Desc.Text = Description
                Desc.TextColor3 = Theme.TextDim
                Desc.TextSize = 11
                Desc.Font = Enum.Font.Gotham
                Desc.TextXAlignment = Enum.TextXAlignment.Left
                Desc.TextWrapped = true
                Desc.Parent = Frame
                table.insert(GUIElements, {Instance = Desc, Key = "TextDim", Property = "TextColor3"})
            end

            local InputContainer = Instance.new("Frame")
            InputContainer.Size = UDim2.new(0, 150, 0, 24)
            InputContainer.Position = UDim2.new(1, -155, 0.5, -12)
            InputContainer.BackgroundTransparency = 1
            InputContainer.BorderSizePixel = 0
            InputContainer.ClipsDescendants = true
            InputContainer.Parent = Frame

            local Input = Instance.new("TextBox")
            Input.Size = UDim2.new(0, 75, 1, 0)
            Input.Position = UDim2.new(1, -75, 0, 0)
            Input.BackgroundColor3 = Theme.Background
            Input.BackgroundTransparency = transparency
            Input.Text = ""
            Input.PlaceholderText = Placeholder
            Input.PlaceholderColor3 = Theme.TextDim
            Input.TextColor3 = Theme.Text
            Input.TextSize = 13
            Input.Font = Enum.Font.Gotham
            Input.ClearTextOnFocus = false
            Input.Parent = InputContainer
            MakeRound(Input, 5)
            table.insert(GUIElements, {Instance = Input, Key = "Background", Property = "BackgroundColor3"})
            table.insert(GUIElements, {Instance = Input, Key = "Text", Property = "TextColor3"})
            table.insert(GUIElements, {Instance = Input, Key = "TextDim", Property = "PlaceholderColor3"})

            local Measurer = Instance.new("TextLabel")
            Measurer.BackgroundTransparency = 1
            Measurer.Text = ""
            Measurer.TextColor3 = Theme.Text
            Measurer.TextSize = 13
            Measurer.Font = Enum.Font.Gotham
            Measurer.Size = UDim2.new(0, 0, 0, 0)
            Measurer.Visible = false
            Measurer.Parent = InputContainer

            local function updateWidth()
                local text = Input.Text ~= "" and Input.Text or Input.PlaceholderText
                Measurer.Text = text
                local width = Measurer.TextBounds.X + 12
                width = math.clamp(width, 60, 150)
                Input.Size = UDim2.new(0, width, 1, 0)
                Input.Position = UDim2.new(1, -width, 0, 0)
            end

            Input:GetPropertyChangedSignal("Text"):Connect(updateWidth)
            updateWidth()

            Input.FocusLost:Connect(function(enter)
                if enter then
                    Callback(Input.Text)
                end
            end)

            return Input
        end

        function Tab:AddSlider(config)
            config = config or {}
            local SliderText = config.Text or "Slider"
            local Description = config.Description
            local Min = config.Min or 0
            local Max = config.Max or 100
            local Default = config.Default or 50
            local Callback = config.Callback or function() end
            local height = Description and 45 or 35

            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, height)
            Frame.BackgroundColor3 = Theme.Input
            Frame.BackgroundTransparency = transparency
            Frame.BorderSizePixel = 0
            Frame.Parent = TabContent
            MakeRound(Frame, 6)
            table.insert(GUIElements, {Instance = Frame, Key = "Input", Property = "BackgroundColor3"})

            local Label = Instance.new("TextLabel")
            Label.BackgroundTransparency = 1
            Label.Text = SliderText
            Label.TextColor3 = Theme.Text
            Label.TextSize = 14
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Frame
            table.insert(GUIElements, {Instance = Label, Key = "Text", Property = "TextColor3"})

            if Description then
                Label.Size = UDim2.new(1, -90, 0, 24)
                Label.Position = UDim2.new(0, 10, 0, 0)
            else
                Label.Size = UDim2.new(1, -90, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
            end

            if Description then
                local Desc = Instance.new("TextLabel")
                Desc.Size = UDim2.new(1, -90, 0, 12)
                Desc.Position = UDim2.new(0, 10, 0, 24)
                Desc.BackgroundTransparency = 1
                Desc.Text = Description
                Desc.TextColor3 = Theme.TextDim
                Desc.TextSize = 11
                Desc.Font = Enum.Font.Gotham
                Desc.TextXAlignment = Enum.TextXAlignment.Left
                Desc.TextWrapped = true
                Desc.Parent = Frame
                table.insert(GUIElements, {Instance = Desc, Key = "TextDim", Property = "TextColor3"})
            end

            local ValueLabel = Instance.new("TextLabel")
            ValueLabel.Size = UDim2.new(0, 40, 1, 0)
            ValueLabel.Position = UDim2.new(1, -45, 0, 0)
            ValueLabel.BackgroundTransparency = 1
            ValueLabel.Text = tostring(Default)
            ValueLabel.TextColor3 = Theme.Accent
            ValueLabel.TextSize = 13
            ValueLabel.Font = Enum.Font.GothamBold
            ValueLabel.TextXAlignment = Enum.TextXAlignment.Right
            ValueLabel.Parent = Frame
            table.insert(GUIElements, {Instance = ValueLabel, Key = "Accent", Property = "TextColor3"})

            local dragging = false
            Frame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    local pos = math.clamp((input.Position.X - Frame.AbsolutePosition.X - 10) / (Frame.AbsoluteSize.X - 100), 0, 1)
                    local value = math.floor(Min + (Max - Min) * pos)
                    ValueLabel.Text = tostring(value)
                    Callback(value)
                end
            end)

            Frame.InputEnded:Connect(function()
                dragging = false
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local pos = math.clamp((input.Position.X - Frame.AbsolutePosition.X - 10) / (Frame.AbsoluteSize.X - 100), 0, 1)
                    local value = math.floor(Min + (Max - Min) * pos)
                    ValueLabel.Text = tostring(value)
                    Callback(value)
                end
            end)

            return {
                Set = function(val)
                    local pos = (val - Min) / (Max - Min)
                    ValueLabel.Text = tostring(val)
                end
            }
        end

        function Tab:AddDropdown(config)
            config = config or {}
            local DropdownText = config.Text or "Option"
            local Description = config.Description
            local Options = config.Options or {"A", "B", "C"}
            local Default = config.Default or Options[1]
            local Callback = config.Callback or function() end
            local hasDesc = Description ~= nil
            local baseHeight = hasDesc and 50 or 35

            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, baseHeight)
            Frame.BackgroundColor3 = Theme.Input
            Frame.BackgroundTransparency = transparency
            Frame.BorderSizePixel = 0
            Frame.Parent = TabContent
            MakeRound(Frame, 6)
            table.insert(GUIElements, {Instance = Frame, Key = "Input", Property = "BackgroundColor3"})

            local Label = Instance.new("TextLabel")
            Label.BackgroundTransparency = 1
            Label.Text = DropdownText
            Label.TextColor3 = Theme.Text
            Label.TextSize = 14
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.Parent = Frame
            table.insert(GUIElements, {Instance = Label, Key = "Text", Property = "TextColor3"})

            if Description then
                Label.Size = UDim2.new(1, -90, 0, 20)
                Label.Position = UDim2.new(0, 10, 0, 5)
            else
                Label.Size = UDim2.new(1, -90, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
            end

            if hasDesc then
                local Desc = Instance.new("TextLabel")
                Desc.Size = UDim2.new(1, -90, 0, 12)
                Desc.Position = UDim2.new(0, 10, 0, 28)
                Desc.BackgroundTransparency = 1
                Desc.Text = Description
                Desc.TextColor3 = Theme.TextDim
                Desc.TextSize = 11
                Desc.Font = Enum.Font.Gotham
                Desc.TextXAlignment = Enum.TextXAlignment.Left
                Desc.TextWrapped = true
                Desc.Parent = Frame
                table.insert(GUIElements, {Instance = Desc, Key = "TextDim", Property = "TextColor3"})
            end

            local Button = Instance.new("TextButton")
            Button.Size = UDim2.new(0, 90, 0, 24)
            Button.Position = UDim2.new(1, -95, 0.5, -12)
            Button.BackgroundColor3 = Theme.Background
            Button.BackgroundTransparency = transparency
            Button.Text = ""
            Button.ClipsDescendants = true
            Button.Parent = Frame
            MakeRound(Button, 5)
            AddStroke(Button, Theme.Border, 1)
            table.insert(GUIElements, {Instance = Button, Key = "Background", Property = "BackgroundColor3"})

            local Selected = Instance.new("TextLabel")
            Selected.Size = UDim2.new(1, -20, 1, 0)
            Selected.Position = UDim2.new(0, 10, 0, 0)
            Selected.BackgroundTransparency = 1
            Selected.Text = Default
            Selected.TextColor3 = Theme.Text
            Selected.TextSize = 13
            Selected.Font = Enum.Font.Gotham
            Selected.TextXAlignment = Enum.TextXAlignment.Left
            Selected.TextXAlignment = Enum.TextXAlignment.Center
            Selected.Parent = Button
            table.insert(GUIElements, {Instance = Selected, Key = "Text", Property = "TextColor3"})

            local Chevron = Instance.new("ImageLabel")
            Chevron.Size = UDim2.new(0, 12, 0, 12)
            Chevron.Position = UDim2.new(1, -18, 0.5, -6)
            Chevron.BackgroundTransparency = 1
            Chevron.ImageColor3 = Theme.TextDim
            Chevron.Parent = Button
            SetImageSafe(Chevron, Icons.ChevronDown)
            table.insert(GUIElements, {Instance = Chevron, Key = "TextDim", Property = "ImageColor3"})

            local Container = Instance.new("ScrollingFrame")
            Container.BackgroundTransparency = 1
            Container.Visible = false
            Container.ScrollBarThickness = 3
            Container.ScrollBarImageColor3 = Theme.Primary
            Container.CanvasSize = UDim2.new(0, 0, 0, 0)
            Container.ZIndex = 100
            Container.Parent = TabContent

            local expanded = false
            local current = Default

            local function closeDropdown()
                if expanded then
                    Container.Visible = false
                    expanded = false
                    Tween(Chevron, {Rotation = 0}, 0.15)
                end
            end

            local closeConn
            local function setupOutsideClose()
                if closeConn then closeConn:Disconnect() end
                closeConn = UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local pos = input.Position
                        local frameAbs = Frame.AbsolutePosition
                        local frameSize = Frame.AbsoluteSize
                        local contAbs = Container.AbsolutePosition
                        local contSize = Container.AbsoluteSize
                        local inFrame = pos.X >= frameAbs.X and pos.X <= frameAbs.X + frameSize.X and
                            pos.Y >= frameAbs.Y and pos.Y <= frameAbs.Y + frameSize.Y
                        local inContainer = Container.Visible and
                            pos.X >= contAbs.X and pos.X <= contAbs.X + contSize.X and
                            pos.Y >= contAbs.Y and pos.Y <= contAbs.Y + contSize.Y
                        if not (inFrame or inContainer) then
                            closeDropdown()
                            if closeConn then closeConn:Disconnect() closeConn = nil end
                        end
                    end
                end)
            end

            local function openDropdown()
                closeDropdown()
                expanded = true
                local frameAbs = Frame.AbsolutePosition
                local frameSize = Frame.AbsoluteSize
                Container.Parent = Tab.ScreenGui
                Container.Position = UDim2.new(0, frameAbs.X, 0, frameAbs.Y + frameSize.Y)
                Container.Size = UDim2.new(0, frameSize.X, 0, 0)

                for _, child in ipairs(Container:GetChildren()) do
                    if child:IsA("GuiObject") or child:IsA("UIComponent") then child:Destroy() end
                end

                local optionHeight = 28
                local spacing = 2
                local totalHeight = #Options * (optionHeight + spacing) - spacing
                Container.CanvasSize = UDim2.new(0, frameSize.X, 0, totalHeight)
                local displayHeight = math.min(totalHeight, 180)
                Tween(Container, {Size = UDim2.new(0, frameSize.X, 0, displayHeight)}, 0.15)

                for i, opt in ipairs(Options) do
                    local yPos = (i - 1) * (optionHeight + spacing)
                    local btn = Instance.new("TextButton")
                    btn.Size = UDim2.new(1, -10, 0, optionHeight)
                    btn.Position = UDim2.new(0, 5, 0, yPos)
                    btn.Text = opt
                    btn.TextColor3 = Theme.Text
                    btn.BackgroundColor3 = opt == current and Theme.Primary or Theme.Input
                    btn.BackgroundTransparency = transparency
                    btn.Font = Enum.Font.Gotham
                    btn.TextSize = 13
                    btn.Parent = Container
                    MakeRound(btn, 4)

                    btn.MouseButton1Click:Connect(function()
                        current = opt
                        Selected.Text = opt
                        Callback(opt)
                        closeDropdown()
                        if closeConn then closeConn:Disconnect() closeConn = nil end
                    end)
                end

                Container.Visible = true
                Tween(Chevron, {Rotation = 180}, 0.15)
                setupOutsideClose()
            end

            Button.MouseButton1Click:Connect(function()
                if expanded then
                    closeDropdown()
                    if closeConn then closeConn:Disconnect() closeConn = nil end
                else
                    task.defer(function()
                        if Frame.Parent then
                            openDropdown()
                        end
                    end)
                end
            end)

            return {
                Set = function(val)
                    current = val
                    Selected.Text = val
                end
            }
        end

        function Tab:AddLabel(text)
            local LabelFrame = Instance.new("Frame")
            LabelFrame.Size = UDim2.new(1, 0, 0, 25)
            LabelFrame.BackgroundTransparency = 1
            LabelFrame.BorderSizePixel = 0
            LabelFrame.Parent = TabContent

            local Label = Instance.new("TextLabel")
            Label.Size = UDim2.new(1, 0, 1, 0)
            Label.Position = UDim2.new(0, 5, 0, 0)
            Label.BackgroundTransparency = 1
            Label.Text = text
            Label.TextColor3 = Theme.TextDim
            Label.TextSize = 13
            Label.Font = Enum.Font.Gotham
            Label.TextXAlignment = Enum.TextXAlignment.Left
            Label.TextWrapped = true
            Label.Parent = LabelFrame
            table.insert(GUIElements, {Instance = Label, Key = "TextDim", Property = "TextColor3"})

            return {
                Set = function(newText)
                    Label.Text = newText
                end
            }
        end

        function Tab:AddParagraph(title, content)
            local Frame = Instance.new("Frame")
            Frame.Size = UDim2.new(1, 0, 0, 60)
            Frame.BackgroundColor3 = Theme.Input
            Frame.BackgroundTransparency = transparency
            Frame.BorderSizePixel = 0
            Frame.Parent = TabContent
            MakeRound(Frame, 6)
            table.insert(GUIElements, {Instance = Frame, Key = "Input", Property = "BackgroundColor3"})

            local TitleLabel = Instance.new("TextLabel")
            TitleLabel.Size = UDim2.new(1, -10, 0, 18)
            TitleLabel.Position = UDim2.new(0, 10, 0, 6)
            TitleLabel.BackgroundTransparency = 1
            TitleLabel.Text = title
            TitleLabel.TextColor3 = Theme.Text
            TitleLabel.TextSize = 14
            TitleLabel.Font = Enum.Font.GothamBold
            TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
            TitleLabel.Parent = Frame
            table.insert(GUIElements, {Instance = TitleLabel, Key = "Text", Property = "TextColor3"})

            local ContentLabel = Instance.new("TextLabel")
            ContentLabel.Size = UDim2.new(1, -20, 1, -30)
            ContentLabel.Position = UDim2.new(0, 10, 0, 28)
            ContentLabel.BackgroundTransparency = 1
            ContentLabel.Text = content
            ContentLabel.TextColor3 = Theme.TextDim
            ContentLabel.TextSize = 12
            ContentLabel.Font = Enum.Font.Gotham
            ContentLabel.TextXAlignment = Enum.TextXAlignment.Left
            ContentLabel.TextYAlignment = Enum.TextYAlignment.Top
            ContentLabel.TextWrapped = true
            ContentLabel.Parent = Frame
            table.insert(GUIElements, {Instance = ContentLabel, Key = "TextDim", Property = "TextColor3"})

            return {
                Set = function(t, c)
                    TitleLabel.Text = t
                    ContentLabel.Text = c
                end
            }
        end

        function Tab:AddSection(title)
            local SectionFrame = Instance.new("Frame")
            SectionFrame.Size = UDim2.new(1, 0, 0, 22)
            SectionFrame.BackgroundTransparency = 1
            SectionFrame.BorderSizePixel = 0
            SectionFrame.Parent = TabContent

            local SectionLabel = Instance.new("TextLabel")
            SectionLabel.Size = UDim2.new(1, 0, 1, 0)
            SectionLabel.Position = UDim2.new(0, 5, 0, 0)
            SectionLabel.BackgroundTransparency = 1
            SectionLabel.Text = title
            SectionLabel.TextColor3 = Theme.Text
            SectionLabel.TextSize = 14
            SectionLabel.Font = Enum.Font.GothamBold
            SectionLabel.TextXAlignment = Enum.TextXAlignment.Left
            SectionLabel.Parent = SectionFrame
            table.insert(GUIElements, {Instance = SectionLabel, Key = "Text", Property = "TextColor3"})

            return {
                Set = function(newTitle)
                    SectionLabel.Text = newTitle
                end
            }
        end

        table.insert(Window.Tabs, Tab)

        if #Window.Tabs == 1 then
            TabBtn.BackgroundTransparency = 0
            TabBtn.BackgroundColor3 = Theme.Primary
            TabIcon_img.ImageColor3 = Theme.Text
            TabLabel.TextColor3 = Theme.Text
            TabContent.Visible = true
            Window.CurrentTab = Tab
            ApplyTheme()
        end

        return Tab
    end

    return Window
end

-- ColorPicker Function - FIXED SV AREA COLOR
function Library:CreateColorPicker(tab, config)
    config = config or {}
    local Title = config.Title or "Color"
    local Default = config.Default or Color3.fromRGB(255, 255, 255)
    local Callback = config.Callback or function() end
    local ThemeKey = config.ThemeKey
    local Transparency = config.Transparency or transparency
    
    local CurrentColor = Default
    local IsOpen = false
    local content = tab.Content or tab
    
    local currentH, currentS, currentV = Color3.toHSV(CurrentColor)
    
    -- Toggle Button
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Name = "ColorPickerToggle_" .. Title:gsub(" ", "_")
    ToggleBtn.Size = UDim2.new(1, -20, 0, 32)
    ToggleBtn.BackgroundColor3 = Theme.Input
    ToggleBtn.BackgroundTransparency = Transparency
    ToggleBtn.Text = "🎨 " .. Title .. "  " .. RGBtoHex(Default)
    ToggleBtn.TextColor3 = Theme.Text
    ToggleBtn.TextSize = 12
    ToggleBtn.Font = Enum.Font.Gotham
    ToggleBtn.ZIndex = 50
    ToggleBtn.Parent = content
    MakeRound(ToggleBtn, 6)
    AddStroke(ToggleBtn, Theme.Border, 1)
    table.insert(GUIElements, {Instance = ToggleBtn, Key = "Input", Property = "BackgroundColor3"})
    table.insert(GUIElements, {Instance = ToggleBtn, Key = "Text", Property = "TextColor3"})
    
    -- Picker Frame
    local PickerFrame = Instance.new("Frame")
    PickerFrame.Name = "ColorPicker_" .. Title:gsub(" ", "_")
    PickerFrame.Size = UDim2.new(1, 0, 0, 0)
    PickerFrame.BackgroundColor3 = Theme.Input
    PickerFrame.BackgroundTransparency = Transparency
    PickerFrame.BorderSizePixel = 0
    PickerFrame.Visible = false
    PickerFrame.ZIndex = 100
    PickerFrame.Parent = content
    table.insert(GUIElements, {Instance = PickerFrame, Key = "Input", Property = "BackgroundColor3"})
    
    -- Header
    local Header = Instance.new("Frame")
    Header.Size = UDim2.new(1, 0, 0, 30)
    Header.BackgroundColor3 = Theme.Sidebar
    Header.BorderSizePixel = 0
    Header.ZIndex = 101
    Header.Parent = PickerFrame
    MakeRound(Header, 8)
    table.insert(GUIElements, {Instance = Header, Key = "Sidebar", Property = "BackgroundColor3"})
    
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Size = UDim2.new(0, 24, 0, 24)
    CloseBtn.Position = UDim2.new(1, -27, 0.5, -12)
    CloseBtn.BackgroundColor3 = Theme.Primary
    CloseBtn.BackgroundTransparency = Transparency
    CloseBtn.Text = "×"
    CloseBtn.TextColor3 = Theme.Text
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.ZIndex = 102
    CloseBtn.Parent = Header
    MakeRound(CloseBtn, 5)
    table.insert(GUIElements, {Instance = CloseBtn, Key = "Primary", Property = "BackgroundColor3"})
    table.insert(GUIElements, {Instance = CloseBtn, Key = "Text", Property = "TextColor3"})
    
    -- Preview Box
    local PreviewBox = Instance.new("Frame")
    PreviewBox.Name = "PreviewBox"
    PreviewBox.Size = UDim2.new(0, 50, 0, 50)
    PreviewBox.Position = UDim2.new(0, 10, 0, 40)
    PreviewBox.BackgroundColor3 = CurrentColor
    PreviewBox.BorderSizePixel = 0
    PreviewBox.ZIndex = 101
    PreviewBox.Parent = PickerFrame
    MakeRound(PreviewBox, 6)
    AddStroke(PreviewBox, Theme.Border, 1)
    
    local HexLabel = Instance.new("TextLabel")
    HexLabel.Name = "HexLabel"
    HexLabel.Size = UDim2.new(0, 70, 0, 18)
    HexLabel.Position = UDim2.new(0, 68, 0, 60)
    HexLabel.BackgroundTransparency = 1
    HexLabel.Text = RGBtoHex(CurrentColor)
    HexLabel.TextColor3 = Theme.TextDim
    HexLabel.TextSize = 10
    HexLabel.Font = Enum.Font.Gotham
    HexLabel.ZIndex = 102
    HexLabel.Parent = PickerFrame
    table.insert(GUIElements, {Instance = HexLabel, Key = "TextDim", Property = "TextColor3"})
    
    -- Hue Slider
    local HueSlider = Instance.new("Frame")
    HueSlider.Size = UDim2.new(0, 12, 0, 80)
    HueSlider.Position = UDim2.new(0, 15, 0, 100)
    HueSlider.BackgroundColor3 = Color3.fromRGB(255,255,255)
    HueSlider.BorderSizePixel = 0
    HueSlider.ZIndex = 101
    HueSlider.Parent = PickerFrame
    MakeRound(HueSlider, 3)
    
    local HueGrad = Instance.new("UIGradient")
    HueGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)),
        ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255,255,0)),
        ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0,255,0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0,255,255)),
        ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0,0,255)),
        ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255,0,255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255,0,0))
    }
    HueGrad.Rotation = 90
    HueGrad.Parent = HueSlider
    
    local HueInd = Instance.new("Frame")
    HueInd.Name = "HueInd"
    HueInd.Size = UDim2.new(1, 4, 0, 3)
    HueInd.BackgroundColor3 = Color3.fromRGB(255,255,255)
    HueInd.BorderSizePixel = 0
    HueInd.ZIndex = 102
    HueInd.Parent = HueSlider
    MakeRound(HueInd, 2)
    
    -- SV Area - FIXED: Background color update setiap kali hue berubah
    local SVArea = Instance.new("Frame")
    SVArea.Size = UDim2.new(0, 80, 0, 80)
    SVArea.Position = UDim2.new(0, 32, 0, 100)
    SVArea.BackgroundColor3 = HSVtoRGB(currentH, 1, 1) -- CRITICAL: Set initial color
    SVArea.BorderSizePixel = 0
    SVArea.ZIndex = 101
    SVArea.Parent = PickerFrame
    MakeRound(SVArea, 4)
    
    -- White gradient (LEFT transparent → RIGHT white) for saturation
    local SVWhiteGradient = Instance.new("UIGradient")
    SVWhiteGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
    }
    SVWhiteGradient.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(1, 0)
    }
    SVWhiteGradient.Rotation = 0
    SVWhiteGradient.Parent = SVArea
    
    -- Black gradient (TOP transparent → BOTTOM black) for value
    local SVBlackGradient = Instance.new("UIGradient")
    SVBlackGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
    }
    SVBlackGradient.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 1),
        NumberSequenceKeypoint.new(1, 0)
    }
    SVBlackGradient.Rotation = 0
    SVBlackGradient.Parent = SVArea
    
    local SVInd = Instance.new("Frame")
    SVInd.Name = "SVInd"
    SVInd.Size = UDim2.new(0, 8, 0, 8)
    SVInd.BackgroundColor3 = Color3.fromRGB(255,255,255)
    SVInd.BorderSizePixel = 0
    SVInd.ZIndex = 104
    SVInd.Parent = SVArea
    MakeRound(SVInd, 4)
    AddStroke(SVInd, Color3.fromRGB(0,0,0), 1)
    
    -- RGB Inputs
    local RInp, GInp, BInp, HexInp
    
    local function RGBInp(lbl, off, ch)
        local L = Instance.new("TextLabel")
        L.Size = UDim2.new(0, 16, 0, 16)
        L.Position = UDim2.new(0, 120, 0, 100+off)
        L.BackgroundTransparency = 1
        L.Text = lbl
        L.TextColor3 = Theme.TextDim
        L.TextSize = 10
        L.Font = Enum.Font.Gotham
        L.ZIndex = 102
        L.Parent = PickerFrame
        table.insert(GUIElements, {Instance = L, Key = "TextDim", Property = "TextColor3"})
        
        local I = Instance.new("TextBox")
        I.Name = ch .. "Inp"
        I.Size = UDim2.new(0, 35, 0, 16)
        I.Position = UDim2.new(0, 140, 0, 100+off)
        I.BackgroundColor3 = Theme.Background
        I.BackgroundTransparency = Transparency
        I.Text = tostring(math.floor(CurrentColor[ch]*255))
        I.PlaceholderText = "0"
        I.PlaceholderColor3 = Theme.TextDim
        I.TextColor3 = Theme.Text
        I.TextSize = 10
        I.Font = Enum.Font.Gotham
        I.ClearTextOnFocus = false
        I.ZIndex = 102
        I.Parent = PickerFrame
        MakeRound(I, 4)
        table.insert(GUIElements, {Instance = I, Key = "Background", Property = "BackgroundColor3"})
        table.insert(GUIElements, {Instance = I, Key = "Text", Property = "TextColor3"})
        table.insert(GUIElements, {Instance = I, Key = "TextDim", Property = "PlaceholderColor3"})
        
        I.FocusLost:Connect(function(ent)
            if ent then
                local v = math.clamp(tonumber(I.Text) or 0, 0, 255)
                I.Text = tostring(v)
                local r = ch=="R" and v/255 or CurrentColor.R
                local g = ch=="G" and v/255 or CurrentColor.G
                local b = ch=="B" and v/255 or CurrentColor.B
                UpdateFromColor(Color3.fromRGB(r*255, g*255, b*255))
            end
        end)
        return I
    end
    
    RInp = RGBInp("R", 0, "R")
    GInp = RGBInp("G", 20, "G")
    BInp = RGBInp("B", 40, "B")
    
    -- Hex Input
    HexInp = Instance.new("TextBox")
    HexInp.Name = "HexInp"
    HexInp.Size = UDim2.new(0, 70, 0, 18)
    HexInp.Position = UDim2.new(0, 120, 0, 165)
    HexInp.BackgroundColor3 = Theme.Background
    HexInp.BackgroundTransparency = Transparency
    HexInp.Text = RGBtoHex(CurrentColor):upper()
    HexInp.PlaceholderText = "#RRGGBB"
    HexInp.PlaceholderColor3 = Theme.TextDim
    HexInp.TextColor3 = Theme.Accent
    HexInp.TextSize = 10
    HexInp.Font = Enum.Font.GothamSemibold
    HexInp.ClearTextOnFocus = false
    HexInp.ZIndex = 102
    HexInp.Parent = PickerFrame
    MakeRound(HexInp, 4)
    table.insert(GUIElements, {Instance = HexInp, Key = "Background", Property = "BackgroundColor3"})
    table.insert(GUIElements, {Instance = HexInp, Key = "Accent", Property = "TextColor3"})
    table.insert(GUIElements, {Instance = HexInp, Key = "TextDim", Property = "PlaceholderColor3"})
    
    HexInp.FocusLost:Connect(function(ent)
        if ent then
            local hx = HexInp.Text:gsub("#","")
            if #hx == 6 then
                local ok, res = pcall(function() return HexToColor3("#"..hx) end)
                if ok and res then UpdateFromColor(res)
                else HexInp.Text = RGBtoHex(CurrentColor):upper() end
            else
                HexInp.Text = RGBtoHex(CurrentColor):upper()
            end
        end
    end)
    
    -- Update UI from HSV
    local function UpdateFromHSV(h, s, v)
        currentH, currentS, currentV = h, s, v
        local color = HSVtoRGB(h, s, v)
        CurrentColor = color
        
        -- Update preview
        PreviewBox.BackgroundColor3 = color
        HexLabel.Text = RGBtoHex(color)
        HexInp.Text = RGBtoHex(color):upper()
        RInp.Text = tostring(math.floor(color.R*255))
        GInp.Text = tostring(math.floor(color.G*255))
        BInp.Text = tostring(math.floor(color.B*255))
        ToggleBtn.Text = "🎨 " .. Title .. "  " .. RGBtoHex(color)
        
        -- CRITICAL: Update SV area background dengan hue yang benar
        SVArea.BackgroundColor3 = HSVtoRGB(h, 1, 1)
        
        -- Update indicator positions
        HueInd.Position = UDim2.new(0, 0, h, -1.5)
        SVInd.Position = UDim2.new(s, -4, 1-v, -4)
        
        -- Update theme
        if ThemeKey and Theme[ThemeKey] then
            Theme[ThemeKey] = color
        end
        
        ApplyTheme()
        Callback(color, Title, ThemeKey)
    end
    
    -- Update from Color
    local function UpdateFromColor(color)
        local h, s, v = Color3.toHSV(color)
        UpdateFromHSV(h, s, v)
    end
    
    -- Toggle Button Event
    ToggleBtn.MouseButton1Click:Connect(function()
        IsOpen = not IsOpen
        PickerFrame.Visible = IsOpen
        if IsOpen then
            PickerFrame.Size = UDim2.new(1, 0, 0, 190)
            -- CRITICAL: Set SVArea background saat pertama kali buka
            SVArea.BackgroundColor3 = HSVtoRGB(currentH, 1, 1)
            HueInd.Position = UDim2.new(0, 0, currentH, -1.5)
            SVInd.Position = UDim2.new(currentS, -4, 1-currentV, -4)
            UpdateFromHSV(currentH, currentS, currentV)
        else
            PickerFrame.Size = UDim2.new(1, 0, 0, 0)
        end
        
        task.defer(function()
            if content and content:IsA("ScrollingFrame") then
                content.CanvasSize = UDim2.new(0, 0, 0, content.AbsoluteContentSize.Y + 10)
            end
        end)
    end)
    
    -- Close Button Event
    CloseBtn.MouseButton1Click:Connect(function()
        IsOpen = false
        PickerFrame.Visible = false
        PickerFrame.Size = UDim2.new(1, 0, 0, 0)
        
        task.defer(function()
            if content and content:IsA("ScrollingFrame") then
                content.CanvasSize = UDim2.new(0, 0, 0, content.AbsoluteContentSize.Y + 10)
            end
        end)
    end)
    
    -- Drag Hue
    local hDrag = false
    HueSlider.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            hDrag = true
            local function upd(pos)
                local absPos = HueSlider.AbsolutePosition
                local absSize = HueSlider.AbsoluteSize
                local y = math.clamp((pos.Y - absPos.Y) / absSize.Y, 0, 1)
                
                HueInd.Position = UDim2.new(0, 0, y, -1.5)
                UpdateFromHSV(y, currentS, currentV)
            end
            upd(inp.Position)
            
            local moveConn, endConn
            moveConn = UserInputService.InputChanged:Connect(function(input)
                if hDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    upd(input.Position)
                end
            end)
            
            endConn = UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    hDrag = false
                    moveConn:Disconnect()
                    endConn:Disconnect()
                end
            end)
        end
    end)
    
    -- Drag SV
    local svDrag = false
    SVArea.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            svDrag = true
            local function upd(pos)
                local absPos = SVArea.AbsolutePosition
                local absSize = SVArea.AbsoluteSize
                local x = math.clamp((pos.X - absPos.X) / absSize.X, 0, 1)
                local y = math.clamp((pos.Y - absPos.Y) / absSize.Y, 0, 1)
                
                SVInd.Position = UDim2.new(x, -4, y, -4)
                UpdateFromHSV(currentH, x, 1-y)
            end
            upd(inp.Position)
            
            local moveConn, endConn
            moveConn = UserInputService.InputChanged:Connect(function(input)
                if svDrag and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    upd(input.Position)
                end
            end)
            
            endConn = UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    svDrag = false
                    moveConn:Disconnect()
                    endConn:Disconnect()
                end
            end)
        end
    end)
    
    -- Init
    task.defer(function() 
        if IsOpen then
            UpdateFromHSV(currentH, currentS, currentV)
        end
    end)
    
    return {
        SetColor = UpdateFromColor,
        GetColor = function() return CurrentColor end,
        ToggleBtn = ToggleBtn,
        PickerFrame = PickerFrame,
        Destroy = function()
            ToggleBtn:Destroy()
            PickerFrame:Destroy()
        end
    }
end

-- Save/Restore/Reset Theme Functions
function Library:SaveTheme()
    local themeData = {}
    for key, color in pairs(Theme) do
        if typeof(color) == "Color3" then
            themeData[key] = {
                R = math.floor(color.R * 255),
                G = math.floor(color.G * 255),
                B = math.floor(color.B * 255)
            }
        end
    end
    return HttpService:JSONEncode(themeData)
end

function Library:RestoreTheme(jsonString)
    local success, themeData = pcall(function()
        return HttpService:JSONDecode(jsonString)
    end)
    if not success then
        warn("Failed to restore theme: Invalid JSON")
        return false
    end
    for key, rgb in pairs(themeData) do
        if Theme[key] and typeof(Theme[key]) == "Color3" then
            Theme[key] = Color3.fromRGB(rgb.R, rgb.G, rgb.B)
        end
    end
    ApplyTheme()
    return true
end

function Library:ResetTheme()
    local defaultTheme = {
        Background = Color3.fromRGB(18, 18, 18),
        Sidebar = Color3.fromRGB(22, 22, 22),
        Primary = Color3.fromRGB(0, 0, 0),
        Secondary = Color3.fromRGB(30, 30, 30),
        Accent = Color3.fromRGB(0, 160, 255),
        Text = Color3.fromRGB(255, 255, 255),
        TextDim = Color3.fromRGB(190, 190, 190),
        Border = Color3.fromRGB(60, 60, 60),
        Input = Color3.fromRGB(28, 28, 28),
        Success = Color3.fromRGB(80, 220, 120),
        Warning = Color3.fromRGB(255, 180, 60)
    }
    for key, color in pairs(defaultTheme) do
        Theme[key] = color
    end
    ApplyTheme()
end

-- Ekspos
Library.Theme = Theme
Library.RGBtoHex = RGBtoHex
Library.HexToColor3 = HexToColor3
Library.HSVtoRGB = HSVtoRGB
Library.SaveTheme = Library.SaveTheme
Library.RestoreTheme = Library.RestoreTheme
Library.ResetTheme = Library.ResetTheme

return Library
